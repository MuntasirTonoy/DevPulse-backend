{
  "info": {
    "name": "DevPulse API",
    "description": "Complete collection for DevPulse - Developer Issue Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"contributor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Issues",
      "item": [
        {
          "name": "Create Issue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"API crashes on large payload\",\n  \"description\": \"When sending a JSON payload larger than 10MB, the server crashes with an OOM error.\",\n  \"type\": \"bug\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/issues",
              "host": ["{{baseUrl}}"],
              "path": ["api", "issues"]
            }
          }
        },
        {
          "name": "Get All Issues",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/issues?sort=newest&status=open",
              "host": ["{{baseUrl}}"],
              "path": ["api", "issues"],
              "query": [
                { "key": "sort", "value": "newest" },
                { "key": "status", "value": "open" },
                { "key": "type", "value": "bug", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Single Issue",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/issues/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "issues", "1"]
            }
          }
        },
        {
          "name": "Update Issue",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"API crashes on payload > 50MB\",\n  \"type\": \"feature_request\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/issues/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "issues", "1"]
            }
          }
        },
        {
          "name": "Delete Issue",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/issues/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "issues", "1"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": "paste_your_jwt_token_here_without_bearer"
    }
  ]
}
